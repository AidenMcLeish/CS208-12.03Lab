extends layout

block content
  h1= title
  ol
  each val in todos
    li
      form(method='POST', action='/update')
        input(type='hidden', name='id', value=val.id)
        input(type='text', name='task', value= val.task, required)
        button(type='submit', class='editbtn') Edit
      if val.completed > 0
        span  - Completed - 
      else
        span  - Not Completed - 
        form(method='POST', action='/updatebtn')
          input(type='hidden', name='id', value=val.id)
          button(type='submit', class='completebtn') ✔
      form(method='POST', action='/delete')
        input(type='hidden', name='id', value=val.id)
        button(type='submit', class='deletebtn') Delete

  hr
  h2 Add a new task
  form(method='POST', action='/create')
    label(for='task') Task:  
    input(type='text', name='task', id='task', required)
    button(type='submit', class='createbtn') Create Task
